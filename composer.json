{
    "name": "npcink/site-toolbox",
    "description": "Npcink Site Toolbox - 面向 WordPress 站点所有者的实用工具箱插件",
    "type": "wordpress-plugin",
    "license": "GPL-2.0-or-later",
    "authors": [
        {
            "name": "Npcink",
            "homepage": "https://www.npc.ink/"
        }
    ],
    "require": {
        "php": ">=7.4"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6",
        "php-stubs/wordpress-stubs": "^6.4",
        "phpstan/phpstan": "^1.10",
        "szepeviktor/phpstan-wordpress": "^1.3"
    },
    "config": {
        "allow-plugins": {
            "php-stubs/wordpress-stubs": true
        },
        "platform": {
            "php": "7.4"
        }
    },
    "scripts": {
        "test": "phpunit --configuration phpunit.xml.dist",
        "phpstan": "phpstan analyse --configuration phpstan.neon --memory-limit=2G --no-progress",
        "settings-contract:generate": "@php tests/support/export-admin-settings-contract.php",
        "settings-contract:check": "@php tests/support/export-admin-settings-contract.php --check",
        "release:build": "bash bin/build-release-zip.sh",
        "release:verify": "bash bin/verify-release-zip.sh"
    }
}
