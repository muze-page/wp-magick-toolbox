{
  "$schema": "https://schemas.wp.org/trunk/block.json",
  "apiVersion": 3,
  "name": "npcink/github-project",
  "version": "3.2.0",
  "title": "GitHub 项目",
  "category": "npcink-site-toolbox",
  "icon": "admin-links",
  "description": "展示公开 GitHub 仓库的描述、主要语言、Stars 和 Forks。",
  "keywords": [ "GitHub", "开源", "项目", "仓库" ],
  "textdomain": "npcink-site-toolbox",
  "attributes": {
    "repositoryUrl": {
      "type": "string",
      "default": ""
    },
    "customDescription": {
      "type": "string",
      "default": ""
    }
  },
  "supports": {
    "html": false,
    "align": [ "wide", "full" ],
    "anchor": true,
    "color": {
      "background": true,
      "text": true
    },
    "spacing": {
      "margin": true,
      "padding": true
    }
  },
  "editorScript": "file:./index.js",
  "style": "file:./style.css"
}
